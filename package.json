{
  "name": "automatizacion-mascotas",
  "version": "0.1.0",
  "description": "Herramienta de recopilación de información de mascotas extraviadas desde grupos de Facebook",
  "license": "ISC",
  "author": "Atlantes",
  "type": "commonjs",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build:main": "tsc",
    "build:renderer": "cross-env NODE_ENV=production webpack --mode production",
    "build": "npm run build:main && npm run build:renderer",
    "dev:renderer": "webpack --mode development --watch",
    "dev:main": "tsc --watch",
    "start": "npm run build && electron .",
    "dev": "npm run build:main && npm run build:renderer && electron .",
    "pack": "electron-builder --dir",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "12.8.0",
    "electron-store": "^8.2.0",
    "node-cron": "^3.0.3",
    "playwright-core": "^1.48.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^25.0.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "postcss": "^8.4.47",
    "postcss-loader": "^8.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.27.0",
    "tailwindcss": "^3.4.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.6.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.0"
  },
  "build": {
    "appId": "com.atlantes.mascotas",
    "productName": "Mascotas Extraviadas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
